# =========================
# 1. Dataset & large outputs
# =========================
dataset/
outputs/
_plot_test/

# Paper/sample figures are tracked under assets/figures/ (NOT under any outputs/),
# so no gitignore exception is needed — they are committed as static assets.

# =========================
# 1b. Data / large artifact extensions (safe at any location)
# =========================
*.npy
*.npz
*.mat
*.dat
*.zip

# =========================
# 1c. csi_cut_tool — raw collection data + tool output (keep on disk, never commit)
# =========================
# Sample/real capture sessions (raw_*.bin, action_events.csv, video.mp4, ...).
tools/csi_cut_tool/sample_data/
# Plot-mode (func=plot) PNG output.
tools/csi_cut_tool/plot_output/
# Cut/synced output the tool writes to its working dir, at any location.
Cut_Data/

# =========================
# 2. Python artifacts
# =========================
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg
*.egg-info/
dist/
build/
.eggs/
venv/
.venv/
env/
.env
.env.*

# =========================
# 3. ML experiment files
# =========================
*.pt
*.pth
*.ckpt
wandb/
mlruns/
lightning_logs/
runs/
*.log

# =========================
# 4. Jupyter Notebook & IDE
# =========================
.ipynb_checkpoints/
.vscode/
.idea/

# =========================
# 5. Claude & OS files
# =========================
.claude/
.DS_Store
Thumbs.db
