# Exception: keep sample plots from 03_plot_amplitude.py in the repo.
# Re-include the path one level at a time (Git can't un-ignore a file whose
# parent dir is excluded); everything else under any outputs/ stays ignored.
!xrf55_bench/outputs/
xrf55_bench/outputs/*
!xrf55_bench/outputs/local_plots/
xrf55_bench/outputs/local_plots/*
!xrf55_bench/outputs/local_plots/*.png

